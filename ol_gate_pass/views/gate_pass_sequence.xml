<odoo>
    <!-- Gate In Sequence -->
    <record id="gate_pass_in_sequence" model="ir.sequence">
        <field name="name">Gate In Sequence</field>
        <field name="code">gate.pass.in.sequence</field>
        <field name="prefix">IGP-</field>
        <field name="padding">5</field>
        <field name="suffix">/%(month)s/%(year)s</field>
        <field name="number_increment">1</field>
        <field name="implementation">no_gap</field>
    </record>

    <!-- Gate Out Sequence -->
    <record id="gate_pass_out_sequence" model="ir.sequence">
        <field name="name">Gate Out Sequence</field>
        <field name="code">gate.pass.out.sequence</field>
        <field name="prefix">OGP-</field>
        <field name="padding">5</field>
        <field name="suffix">/%(month)s/%(year)s</field>
        <field name="number_increment">1</field>
        <field name="implementation">no_gap</field>
    </record>

    <!-- RGP Sequence -->
    <record id="gate_pass_rgp_sequence" model="ir.sequence">
        <field name="name">RGP Sequence</field>
        <field name="code">gate.pass.rgp.sequence</field>
        <field name="prefix">RGP-</field>
        <field name="padding">5</field>
        <field name="suffix">/%(month)s/%(year)s</field>
        <field name="number_increment">1</field>
        <field name="implementation">no_gap</field>
    </record>
</odoo>
