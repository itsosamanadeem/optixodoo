    <record id="rule_purchase_manager" model="ir.rule">
        <field name="name">Manager Department RFQ Access</field>
        <field name="model_id" ref="purchase_inherit.model_purchase_order"/>
        <field name="domain_force">
            ['|',
                ('department_id.manager_id.user_id', '=', user.id),
                ('order_line', 'any', [('department_id.manager_id.user_id', '=', user.id)])
            ]
        </field>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>
    <record id="rule_purchase_scm_user" model="ir.rule">
        <field name="name">SCM User Full Access</field>
        <field name="model_id" ref="purchase_inherit.model_purchase_order"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('purchase_inherit.group_scm_user'))]"/>
    </record>
    <record id="rule_purchase_scm" model="ir.rule">
        <field name="name">SCM Manager Full Access</field>
        <field name="model_id" ref="purchase_inherit.model_purchase_order"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('purchase_inherit.group_scm'))]"/>
    </record>
    <record id="rule_purchase_ceo" model="ir.rule">
        <field name="name">CEO Full Access</field>
        <field name="model_id" ref="purchase_inherit.model_purchase_order"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('purchase_inherit.group_ceo'))]"/>
    </record>
</odoo>