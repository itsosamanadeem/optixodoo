<odoo>
    <record id="group_scm" model="res.groups">
        <field name="name">SCM</field>
        <field name="privilege_id" ref="purchase.res_groups_privilege_purchase"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user')),(4, ref('purchase.group_purchase_manager'))]"/>
    </record>

    <record id="group_ceo" model="res.groups">
        <field name="name">CEO</field>
        <field name="privilege_id" ref="purchase.res_groups_privilege_purchase"/>
        <field name="implied_ids" eval="[(4, ref('purchase_inherit.group_scm'))]"/>
    </record>
</odoo>