<odoo>
    <record id="purchase_form_view" model="ir.ui.view">
        <field name="name">purchase.order.form.view.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="/form//div[@name='reminder']" position="after">
                <field name="department_id" readonly="1"/>
            </xpath>
            <xpath expr="/form//widget[@name='purchase_file_uploader']" position="attributes">
                <attribute name="groups">purchase_inherit.group_ceo,purchase_inherit.group_scm,purchase_inherit.group_scm_user</attribute>
            </xpath>
            <xpath expr="/form/header/button[@name='action_rfq_send'][3]" position="attributes">
                <attribute name="groups">purchase_inherit.group_ceo,purchase_inherit.group_scm,purchase_inherit.group_scm_user</attribute>
            </xpath>
            <xpath expr="/form//button[@name='button_unlock']" position="attributes">
                <attribute name="groups">purchase_inherit.group_ceo,purchase_inherit.group_scm,purchase_inherit.group_scm_user</attribute>
            </xpath>
            <!-- <xpath expr="/form//field[@name='picking_type_id']" position="after">
                <field name="is_sent_back" readonly="1"/>
            </xpath> -->
        </field>
    </record>
</odoo>