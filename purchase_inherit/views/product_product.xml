<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_form_inherit_gl" model="ir.ui.view">
        <field name="name">product.product.form.inherit.gl</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="/form[@name='Product Template']//field[@name='property_account_expense_id']" position="after">
                <field name="analytic_gl_id"/>
            </xpath>
        </field>
    </record>
</odoo>