<odoo>
    <record id="approval_request_form_view" model="ir.ui.view">
        <field name="name">approval.request.form.view.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="/form/header/button[@name='action_confirm'][2]" position="attributes">
                <attribute name="invisible">attachment_number &gt;= 1 or request_status != 'new'</attribute>
            </xpath>
            <xpath expr="/form//field[@name='product_line_ids']" position="inside">
                <list editable="bottom" string="Products" decoration-danger="has_no_seller">
                    <field name="company_id" column_invisible="True"/>
                    <field name="product_id" required="parent.approval_type != 'purchase' and parent.has_product == 'required'" context="{'search_default_filter_to_purchase': 1}"/>
                    <field optional="show" name="gl_product"/>
                    <field optional="show" name="department_ids" widget="many2many_tags"/>
                    <field optional="show" name="analytic_distribution" widget="analytic_distribution_po"/>
                    <field name="description"/>
                    <field name="quantity" column_invisible="parent.has_quantity == 'no'" required="parent.has_quantity == 'required' and parent.request_status != 'new'"/>
                    <field name="product_uom_id" groups="uom.group_uom" widget="many2one_uom" options="{'no_create': True, 'no_open': True}"/>
                    <field name="seller_id" column_invisible="parent.approval_type != 'purchase'" domain="[('product_tmpl_id', '=', product_template_id)]" options="{'no_quick_create': True}" context="{                         'default_product_tmpl_id': product_template_id,                         'default_product_id': product_id,                         'unset_res_partner_category_id': True,                     }"/>
                </list>
            </xpath>
        </field>
    </record>
</odoo>