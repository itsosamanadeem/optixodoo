<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_budget_warning_wizard" model="ir.ui.view">
        <field name="name">budget.warning.wizard.form</field>
        <field name="model">budget.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Budget Warning">
                <group>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button name="action_proceed" type="object"
                            string="Proceed" class="btn-primary"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>